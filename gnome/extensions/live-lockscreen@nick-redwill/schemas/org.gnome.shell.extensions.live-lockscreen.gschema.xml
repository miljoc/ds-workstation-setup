<schemalist>
    <schema id="org.gnome.shell.extensions.live-lockscreen" path="/org/gnome/shell/extensions/live-lockscreen/">
        <key name="general-disable-on-battery" type="b">
            <default>false</default>
            <summary>Whether to disable the extension when on battery</summary>
        </key>
        <key name="background-video-path" type="s">
            <default>""</default>
            <summary>Path to background video</summary>
        </key>
        <key name="background-video-scaling-mode" type="i">
            <range min="0" max="2" />
            <default>0</default>
            <summary>Background video scaling mode</summary>
        </key>
        <key name="background-video-blur-radius" type="i">
            <range min="0" max="100" />
            <default>0</default>
            <summary>Background video blur radius</summary>
        </key>
        <key name="background-video-blur-brightness" type="d">
            <range min="0" max="1" />
            <default>0.65</default>
            <summary>Background video brightness</summary>
        </key>
        <key name="background-video-use-videorate" type="b">
            <default>false</default>
            <summary>Whether to use videorate element in pipeline</summary>
        </key>
        <key name="background-video-framerate" type="i">
            <range min="1" max="120" />
            <default>25</default>
            <summary>Background video framerate</summary>
        </key>
        <key name="background-video-looped" type="b">
            <default>true</default>
            <summary>Is background video looped</summary>
        </key>
        <key name="background-audio-volume" type="i">
            <range min="0" max="100" />
            <default>0</default>
            <summary>Background audio volume</summary>
        </key>
        <key name="background-fade-in-duration" type="i">
            <range min="0" max="600000" />
            <default>500</default>
            <summary>Background fade-in animation duration</summary>
        </key>

        <key name="prompt-pause-video" type="b">
            <default>false</default>
            <summary>Whether to pause the video on password prompt</summary>
        </key>
        <key name="prompt-grayscale" type="b">
            <default>false</default>
            <summary>Whether to grayscale the video on password prompt</summary>
        </key>
        <key name="prompt-change-blur" type="b">
            <default>false</default>
            <summary>Whether to change the blur value on password prompt</summary>
        </key>
        
        <key name="prompt-blur-radius" type="i">
            <range min="0" max="100" />
            <default>20</default>
            <summary>Background video blur radius on password prompt</summary>
        </key>
        <key name="prompt-blur-brightness" type="d">
            <range min="0" max="1" />
            <default>0.65</default>
            <summary>Background video brightness on password prompt</summary>
        </key>
        <key name="prompt-blur-anim-duration" type="i">
            <range min="0" max="600000" />
            <default>300</default>
            <summary>Background video blur change animation duration</summary>
        </key>

        <key name="debug-use-color-accurate" type="b">
            <default>true</default>
            <summary>Whether to use color accurate pipeline with conversion</summary>
        </key>
        <key name="debug-force-fullscreen" type="b">
            <default>false</default>
            <summary>Whether to force fullscreen on player windows (not recommended)</summary>
        </key>
        <key name="debug-force-gif-support" type="b">
            <default>false</default>
            <summary>Whether to force GIF support on older gnome versions (not recommended)</summary>
        </key>
    </schema>
</schemalist>